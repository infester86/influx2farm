{
  "name": "influx2farm",
  "version": "1.0.0",
  "description": "Export InfluxDB v2 data to CSV (Windows desktop)",
  "author": "",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run build:app && electron-builder --win",
    "build:app": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "svelte-check --tsconfig ./tsconfig.web.json && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "dotenv": "^16.4.7",
    "fast-csv": "^5.0.2",
    "flatpickr": "^4.6.13",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^22.13.10",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "svelte": "^5.20.5",
    "svelte-check": "^4.1.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.1"
  },
  "build": {
    "appId": "com.influx2farm.app",
    "productName": "Influx2Farm",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
